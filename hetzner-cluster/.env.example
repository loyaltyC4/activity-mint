# Activity Mint — Hetzner Cluster Environment Configuration (TEMPLATE)
#
# Copy this file to .env and fill in REAL values on the Hetzner host:
#   cp .env.example .env
#   nano .env
#
# NEVER commit the real .env to git. This template stays with placeholders.

# ── Shared scraper secret (matches Vercel env var SCRAPER_SECRET) ────────
# Generate a long random string, set the same value in Vercel.
SCRAPER_SECRET=CHANGEME_long_random_string

# ── Proxy credentials (shared across all 5 workers) ─────────────────────
# Each worker uses these creds with its OWN dedicated host IP.
PROXY_USER=CHANGEME_proxy_user
PROXY_PASS=CHANGEME_proxy_pass
PROXY_HTTP_PORT=50100

# ── Worker 1: account → 168.158.21.28 ───────────────────────────────────
# Format from accmarket = username:password:totp_secret
IG_USER_1=CHANGEME_username
IG_PASS_1=CHANGEME_password
IG_2FA_1=CHANGEME_base32_totp_secret

# ── Worker 2: account → 165.254.99.133 ──────────────────────────────────
IG_USER_2=CHANGEME_username
IG_PASS_2=CHANGEME_password
IG_2FA_2=CHANGEME_base32_totp_secret

# ── Worker 3: account → 65.195.109.107 ──────────────────────────────────
IG_USER_3=CHANGEME_username
IG_PASS_3=CHANGEME_password
IG_2FA_3=CHANGEME_base32_totp_secret

# ── Worker 4: account → 161.77.140.110 ──────────────────────────────────
IG_USER_4=CHANGEME_username
IG_PASS_4=CHANGEME_password
IG_2FA_4=CHANGEME_base32_totp_secret

